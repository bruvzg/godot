	<constants>
		<constant name="TEXT_DIRECTION_AUTO" value="0" enum="TextShapingDirection">
			Detect text direction automaticaly.
		</constant>
		<constant name="TEXT_DIRECTION_LTR_TB" value="1" enum="TextShapingDirection">
			Character flow direction: left-to-right, Line flow direction: top-to-bottom.
		</constant>
		<constant name="TEXT_DIRECTION_RTL_TB" value="2" enum="TextShapingDirection">
			Character flow direction: right-to-left, Line flow direction: top-to-bottom. Supported only if shaping interface have [code]TEXT_SHAPING_COMPLEX_LAYOUT[/code] flag set.
		</constant>
		<constant name="TEXT_DIRECTION_TTB_LR" value="3" enum="TextShapingDirection">
			Character flow direction: top-to-bottom, Line flow direction: left-to-right. Supported only if shaping interface have [code]TEXT_SHAPING_VERTICAL_LAYOUT[/code] flag set.
		</constant>
		<constant name="TEXT_DIRECTION_TTB_RL" value="3" enum="TextShapingDirection">
			Character flow direction: top-to-bottom, Line flow direction: right-to-left. Supported only if shaping interface have [code]TEXT_SHAPING_VERTICAL_LAYOUT[/code] flag set.
		</constant>
		<constant name="TEXT_SHAPING_SIMPLE_LAYOUT" value="1" enum="TextShapingCapabilities">
			If this bit is set, shaping interface supports unshaped LTR text.
		</constant>
		<constant name="TEXT_SHAPING_COMPLEX_LAYOUT" value="2" enum="TextShapingCapabilities">
			If this bit is set, shaping interface supports BiDi layouts and contextual shaping.
		</constant>
		<constant name="TEXT_SHAPING_VERTICAL_LAYOUT" value="4" enum="TextShapingCapabilities">
			If this bit is set, shaping interface supports vertical layouts.
		</constant>
	</constants>
